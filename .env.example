# --- FRONTEND (Publicly Accessible Prefix: VITE_) ---
# These are required by Vite to be accessible from the browser
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- BACKEND (Private/Server-Only Variables) ---
# DO NOT prefix these with VITE_ if you don't want them in the browser build
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Other Backend Config
PORT=3000
NODE_ENV=development

# --- OPTIONAL AI CONFIG ---
# (Prefix with VITE_ if used on frontend, otherwise leave as is for backend)
GEMINI_API_KEY=your-gemini-key
ELEVENLABS_API_KEY=your-elevenlabs-key
